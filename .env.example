NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role key (server-only, bypasses RLS).
# Used by Demo Mode seed/wipe routes. Get it from the Supabase dashboard:
# Project Settings > API > service_role key. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google OAuth credentials (for server-side token refresh)
# Get these from Google Cloud Console > APIs & Services > Credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Resend (transactional email). All three must be set for new-access-request
# notifications to fire; if any is missing, the notify call is a no-op.
# 1. Sign up at resend.com, verify dailywins.school as a sending domain.
# 2. Create an API key with send-only permission.
# 3. NOTIFY_FROM_EMAIL must be on a verified domain (e.g. noreply@dailywins.school).
# 4. NOTIFY_TO_EMAIL is who gets paged when a new beta request lands.
RESEND_API_KEY=your-resend-api-key
NOTIFY_FROM_EMAIL=noreply@dailywins.school
NOTIFY_TO_EMAIL=devin@surestepeducation.com
